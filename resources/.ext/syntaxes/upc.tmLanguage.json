{
  "$schema": "https://raw.githubusercontent.com/martinring/tmLanguage/master/tmLanguage.json",
  "name": "UPC Config",
  "scopeName": "source.upc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#key-value" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign",
          "begin": "#!",
          "end": "$"
        }
      ]
    },
    
    "key-value": {
      "patterns": [
        {
          "begin": "^(\\s*)([a-zA-Z_][a-zA-Z0-9_.]*)\\s*:",
          "beginCaptures": {
            "2": { "name": "entity.other.attribute-name" }
          },
          "end": "(?=\\s*#!|$)",
          "patterns": [
            { "include": "#value" }
          ]
        }
      ]
    },
    
    "value": {
      "patterns": [
        { "include": "#string-value" },
        { "include": "#array-value" }
      ]
    },
    
    "string-value": {
      "begin": "\\(",
      "end": "\\)",
      "patterns": [
        {
          "name": "string.quoted.double",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape",
              "match": "\\\\."
            },
            {
              "name": "variable.other",
              "match": "\\$\\{[^}]+\\}"
            }
          ]
        }
      ]
    },
    
    "array-value": {
      "begin": "\\(",
      "end": "\\)",
      "patterns": [
        {
          "name": "meta.array",
          "begin": "\\[",
          "end": "\\]",
          "patterns": [
            {
              "name": "string.quoted.double",
              "begin": "\"",
              "end": "\"",
              "patterns": [
                {
                  "name": "constant.character.escape",
                  "match": "\\\\."
                },
                {
                  "name": "variable.other",
                  "match": "\\$\\{[^}]+\\}"
                }
              ]
            },
            {
              "name": "constant.numeric",
              "match": "\\b\\d+(\\.\\d+)?\\b"
            },
            {
              "name": "constant.language",
              "match": "\\b(true|false|null)\\b"
            }
          ]
        }
      ]
    }
  }
}