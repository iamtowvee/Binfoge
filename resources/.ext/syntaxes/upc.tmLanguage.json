{
  "$schema": "https://raw.githubusercontent.com/martinring/tmLanguage/master/tmLanguage.json",
  "name": "UPC Config",
  "scopeName": "source.upc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#key-colon" },
    { "include": "#key-equals" },
    { "include": "#operator-equals" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.number-sign",
      "begin": "#!",
      "end": "$"
    },
    
    "key-colon": {
      "name": "keyword.control",
      "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_.]*)\\s*:"
    },
    
    "key-equals": {
      "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_.]*)\\s*(?==)",
      "captures": {
        "1": { "name": "variable.other" }
      }
    },
    
    "operator-equals": {
      "name": "keyword.operator",
      "match": "="
    },
    
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape",
              "match": "\\\\."
            },
            {
              "name": "variable.other",
              "match": "\\$\\{[^}]+\\}"
            }
          ]
        }
      ]
    },
    
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric",
          "match": "(?<![\"\\w])\\d+(\\.\\d+)?(?![\"\\w])"
        }
      ]
    },
    
    "constants": {
      "patterns": [
        {
          "name": "entity.name.function",
          "match": "(?<![\"\\w])(true|false|null)(?![\"\\w])"
        }
      ]
    }
  }
}